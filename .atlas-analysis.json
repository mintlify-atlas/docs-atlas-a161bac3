  "keyFeatures": [
    "On-device face recognition with FaceNet embeddings",
    "Real-time face detection using MediaPipe or MLKit",
    "Vector database storage with ObjectBox for fast nearest-neighbor search",
    "Face anti-spoofing detection using FASNet models",
    "Support for multiple FaceNet models (128-dim and 512-dim embeddings)",
    "Configurable search algorithms (ANN vs precise NN search)",
    "Modern Android architecture with Jetpack Compose",
    "TensorFlow Lite inference with GPU acceleration support"
  ],
